{
  "permissions": {
    "allow": [
      "mcp__plugin_playwright_playwright__browser_navigate",
      "mcp__plugin_playwright_playwright__browser_resize",
      "mcp__plugin_playwright_playwright__browser_evaluate",
      "Bash(python3 -m http.server 8743 --bind 127.0.0.1)",
      "Bash(echo \"PID=$!\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://127.0.0.1:8743/index.html)",
      "mcp__plugin_playwright_playwright__browser_click",
      "Bash(python3 -m http.server 8753)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8753/index.html)",
      "Bash(awk 'NR>=1080 && NR<=1400' index.html)"
    ]
  }
}
